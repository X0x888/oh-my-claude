# oh-my-claude.conf — example template
#
# This file documents every runtime flag oh-my-claude understands. Copy it
# to one of:
#
#   ~/.claude/oh-my-claude.conf        (user-wide — applies to every project)
#   <project>/.claude/oh-my-claude.conf (project-only — overrides user-wide)
#
# Then uncomment the lines you want to change. Lines starting with `#` are
# ignored. Anything not set takes the documented default.
#
# Precedence (highest first):
#   env var > project conf > user conf > built-in default
#
# So `OMC_AUTO_MEMORY=off claude` always wins, no matter what the conf says.
#
# Tip: for a guided multi-choice walkthrough, run /omc-config inside Claude
# Code. It edits this file for you (atomic writes, validation), recommends
# defaults aligned with the project's intended posture, and hands off to
# install-resume-watchdog.sh / switch-tier.sh when those are needed.

# ---------------------------------------------------------------------------
# Quality gates — what blocks Stop and how strictly.
# ---------------------------------------------------------------------------

# Gate enforcement depth.
#   basic     — quality gate only (least friction).
#   standard  — quality + excellence gates.
#   full      — adds dimension/traceability gates on complex tasks. (Default.)
# Env: OMC_GATE_LEVEL.
#gate_level=full

# Behavior when a gate's block-cap is reached.
#   silent    — silently release; gate stops blocking. (Legacy: release.)
#   scorecard — emit a scorecard summarizing what was missed, then release.
#               (Default. Legacy: warn.)
#   block     — keep blocking — strictest posture. (Legacy: strict.)
# Env: OMC_GUARD_EXHAUSTION_MODE.
#guard_exhaustion_mode=scorecard

# Minimum verification confidence (0–100) to satisfy the verify gate.
# Default 40 blocks lint-only checks (shellcheck=30, bash -n=30) while
# accepting project test suites (npm test=70+) and framework runs (jest=50+).
# Env: OMC_VERIFY_CONFIDENCE_THRESHOLD.
#verify_confidence_threshold=40

# Capture advisory specialists' findings (council lenses, metis,
# briefing-analyst) and gate Stop until each is shipped or deferred.
#   on  — capture + gate. (Default.)
#   off — kill switch; useful when heuristic extraction is noisy on a
#         specific project's prose style.
# Env: OMC_DISCOVERED_SCOPE.
#discovered_scope=on

# Block destructive git/gh ops (push, force-push, branch -D, reset --hard,
# rebase, gh pr create, etc.) while task_intent is advisory / session-
# management / checkpoint. Defense against the 2026-04-17-class incident.
#   true  — block (default).
#   false — directive layer only; user accepts the risk.
# Env: OMC_PRETOOL_INTENT_GUARD.
#pretool_intent_guard=true

# Wave-plan freshness window (seconds) for the pretool guard's wave
# exception. When a council Phase 8 plan is active and updated within this
# window, `git commit` is allowed even under non-execution intent. Default
# 1800s = 30 min. Stale plans never grant the exception.
# Env: OMC_WAVE_OVERRIDE_TTL_SECONDS.
#wave_override_ttl_seconds=1800

# Internal gate tuning. Most users never touch these.
#stall_threshold=12              # consecutive Read/Grep before stall fires
#excellence_file_count=3         # edited files that trigger excellence-reviewer
#dimension_gate_file_count=3     # edited files that trigger dimension gate
#traceability_file_count=6       # edited files that require briefing-analyst

# Pipe-separated glob patterns of MCP tools that count as verification.
# Example: mcp__cypress__*|mcp__custom_api_tester__*
# Built-in matchers cover Playwright + computer-use; this widens the set.
# Env: OMC_CUSTOM_VERIFY_MCP_TOOLS.
#custom_verify_mcp_tools=

# ---------------------------------------------------------------------------
# Bias-defense — opt-in directives that catch "confident wrong" failures.
# All three default OFF. Toggle on for high-stakes work or after a few
# misroutes; explicit opt-in matches the "first-do-no-harm" stance.
# ---------------------------------------------------------------------------

# Block Stop on a complex plan (≥5 steps, ≥3 files, ≥2 waves, or migration/
# refactor/schema/breaking keyword paired with non-trivial scope) until
# metis has run a stress-test review. Default off.
# Env: OMC_METIS_ON_PLAN_GATE.
#metis_on_plan_gate=off

# Inject a declare-and-proceed directive when a short, unanchored,
# product-shaped prompt arrives (build/create/design + app/dashboard/
# feature, no code anchors). The directive tells the model to state its
# scope interpretation (audience, primary success criterion, non-goals)
# in one or two declarative sentences as part of its opener and proceed
# — under ULW the user's request IS the permission, so the model never
# pauses for confirmation. /prometheus is reserved for the credible-
# approach-split case from core.md (two interpretations credibly
# incompatible AND choosing wrong would cost rework). Default off.
# (Reframed v1.24.0 — the prior wording asked the model to consider
# /prometheus before editing, which a small set of users reported as a
# ULW hold.) Env: OMC_PROMETHEUS_SUGGEST.
#prometheus_suggest=off

# Inject a declare-and-proceed directive telling the model to state its
# interpretation of the goal in one declarative sentence as part of its
# opener (e.g., "I'm interpreting this as <X> and proceeding now") and
# start work — never pause for confirmation. Lighter than prometheus —
# one declarative sentence, not two plus non-goals. Pause case is narrow:
# only stop when both confidence is low AND the wrong call would be hard
# to reverse. Suppressed when prometheus_suggest already fires on the
# same turn. Default off. (Reframed v1.24.0 — see prometheus_suggest
# above for the same rationale.) Env: OMC_INTENT_VERIFY_DIRECTIVE.
#intent_verify_directive=off

# Inject an EXEMPLIFYING SCOPE DETECTED directive when the prompt uses
# example markers ("for instance", "e.g.", "such as", "as needed",
# "like X", "similar to", "including but not limited to") OR (v1.26.0)
# completeness vocabulary ("anything else", "find all", "is it clean",
# "did you cover", "any other surfaces", "exhaustive sweep", "every
# consumer", "orphan files", etc.). Tells the model to define the
# search universe explicitly, enumerate each candidate, and verify each
# (presence-of-verified-checks beats absence-of-known-bads), and to NOT
# trust its own session-authored documentation as evidence. v1.23.0
# version was gated to fresh-execution intent only — that gating let
# the iOS-orphan-files prompt "anything else? for instance, support.html?"
# slip through silently because question-mark framing classified it as
# advisory; v1.26.0 fires on advisory + execution + continuation while
# preserving the v1.23.0 example-marker-only sub-case (with checklist
# workflow) under execution intent. Symmetric to prometheus/intent-verify
# but defends against the OPPOSITE bias (under-commitment /
# under-interpretation / silent-confab). Default ON because it's
# informational rather than blocking — the BLOCKING scope-checklist
# gate (exemplifying_scope_gate) stays gated to the narrow trigger.
# Set to off if the directive is too chatty for your style -- the
# calibration test in core.md still applies regardless.
# Env: OMC_EXEMPLIFYING_DIRECTIVE.
#exemplifying_directive=on

# Hard gate for exemplified scope. When `on`, execution prompts with
# example markers must record an `exemplifying_scope.json` checklist via
# record-scope-checklist.sh; stop-guard blocks until every sibling item
# is marked shipped or declined with a concrete WHY. Default ON because
# the directive alone is not enough to prevent literal-minimum execution.
# Env: OMC_EXEMPLIFYING_SCOPE_GATE.
#exemplifying_scope_gate=on

# PreTool guard's raw-prompt-text trust override. When the classifier
# mis-routes a prompt as advisory but the most recent user prompt
# unambiguously authorizes the destructive verb being attempted, allow
# the op through and record a `prompt_text_override` gate event.
# Defense-in-depth that closes the long-tail of imperative-tail prompt
# shapes the regex layer can't fully cover. Default ON because the
# failure mode it defends against (model parroting "reply with: ship
# the commit on <branch>") was the primary v1.22.x UX complaint.
# Safety: requires both is_imperative_request match AND segment-level
# verb authorization (every destructive segment must be authorized).
# Set to off if you prefer the strict "classifier intent is final"
# behavior. Env: OMC_PROMPT_TEXT_OVERRIDE.
#prompt_text_override=on

# mark-deferred require-WHY validator. When `on`, /mark-deferred
# rejects bare "out of scope" / "not in scope" / "follow-up" /
# "separate task" / "later" / "low priority" reasons that have
# historically been used as silent-skip escape hatches. Reasons must
# contain a WHY keyword (requires/blocked/superseded/awaiting/pending/
# etc.) OR be a self-explanatory single token from the allowlist
# (duplicate / obsolete / superseded / wontfix / invalid / not
# applicable / n/a / not a bug). Default ON because the user explicitly
# identified this as a notorious escape pattern in v1.22.x and earlier.
# Env: OMC_MARK_DEFERRED_STRICT.
#mark_deferred_strict=on

# Statusline shows a yellow `↑v<version>` arrow when the source repo is
# ahead of the installed bundle. Useful nudge to re-run install.sh after
# `git pull`. Default true.
# Env: OMC_INSTALLATION_DRIFT_CHECK.
#installation_drift_check=true

# ---------------------------------------------------------------------------
# Memory & telemetry — what gets persisted across sessions.
# ---------------------------------------------------------------------------

# Cross-session auto-memory writes (project_*.md, feedback_*.md,
# user_*.md, reference_*.md) at session-stop and pre-compact. Default on.
# Set to off for shared machines, regulated codebases, or any context
# where session memory should not accrue. Explicit user requests
# ("remember that…") still apply regardless.
# Env: OMC_AUTO_MEMORY.
#auto_memory=on

# Per-turn classifier telemetry — every UserPromptSubmit records intent +
# domain + a 200-char prompt preview to per-session
# `classifier_telemetry.jsonl`. Cross-session aggregate feeds /ulw-report's
# misfire panel. Default on. Set to off for shared machines / regulated
# codebases (no prompt previews on disk).
# Env: OMC_CLASSIFIER_TELEMETRY.
#classifier_telemetry=on

# ---------------------------------------------------------------------------
# Cost & model tier.
# ---------------------------------------------------------------------------

# Model tier applied to all 32 specialist agents.
#   quality  — all agents use Opus (highest quality, highest cost).
#   balanced — Opus for planning/review, Sonnet for execution. (Default.)
#   economy  — all agents use Sonnet (lowest cost).
#
# Note: this flag is set by `bash install.sh --model-tier=<tier>` and by
# `bash ~/.claude/switch-tier.sh <tier>`. /omc-config also writes it. The
# value here only takes effect on agent files when the tier-switching
# script runs — editing this line by hand will not rewrite agent files.
#model_tier=balanced

# Output style installer behavior. Controls which bundled output-style
# name `bash install.sh` writes into ~/.claude/settings.json's outputStyle.
# Both bundled style files (oh-my-claude.md, executive-brief.md) are always
# copied into ~/.claude/output-styles/ regardless — this flag only chooses
# which one settings.json points at.
#   opencode   — bundled oh-my-claude style (default). Compact, polished CLI
#                report with strong visual hierarchy. Implementation-first
#                framing — Changed / Verification / Risks / Next.
#   executive  — bundled executive-brief style. CEO-grade status briefing.
#                Headline first, status verbs (Shipped / Blocked / At-risk /
#                In-flight / Deferred / No-op), explicit Risks and Asks
#                sections, decisive Next. For users who want decisive,
#                signal-heavy reports.
#   preserve   — leave settings.json's outputStyle untouched (including
#                unset). Useful when you have your own custom output style
#                and do not want install.sh to ever set it.
# When the setting is `opencode` or `executive`, the installer rewrites
# settings.outputStyle on every install — switching the conf flag and
# re-running install moves a user between the two bundled styles. A
# settings.outputStyle that does NOT match a bundled style name (i.e. a
# user's custom style) is always preserved. Upgrades from the legacy
# "OpenCode Compact" name are migrated automatically.
# Env: OMC_OUTPUT_STYLE.
#output_style=opencode

# Auto-triggered council dispatches inherit `--deep` semantics — every
# lens uses opus instead of sonnet. Default off; meaningfully more
# expensive per run. Explicit `/council --deep` always escalates
# regardless. Quality-first users on `model_tier=quality` are the
# typical opt-in.
# Env: OMC_COUNCIL_DEEP_DEFAULT.
#council_deep_default=off

# ---------------------------------------------------------------------------
# Auto-resume harness — recover after Claude Code's rate-limit kill.
# Three layers: substrate (capture), SessionStart hint (surface), watchdog
# (auto-relaunch).
# ---------------------------------------------------------------------------

# Substrate. Capture original_objective + last_user_prompt + reset epoch
# into <session>/resume_request.json on every fatal Stop (rate_limit,
# authentication_failed, billing_error, etc.). Default on; opt out for
# shared machines / regulated codebases. Disabling here ALSO disables
# the SessionStart hint and the watchdog (they have nothing to act on).
# Env: OMC_STOP_FAILURE_CAPTURE.
#stop_failure_capture=on

# Days a `resume_request.json` stays claimable by the SessionStart hint
# and the watchdog. Older artifacts are silently skipped. Default 7 — long
# enough for the 7-day rate-limit window plus slack, short enough that a
# crashed-and-forgotten resume from last month won't surprise the user.
# Env: OMC_RESUME_REQUEST_TTL_DAYS.
#resume_request_ttl_days=7

# Headless watchdog daemon — the autonomous part. When a rate-limit window
# clears, atomically claims an unclaimed `resume_request.json` and launches
# `claude --resume <session> '<original prompt>'` in a detached `tmux`
# session. Default off; opt-in is meaningful behavior change.
#
# Setting this flag alone does NOT register the scheduler. Run:
#   bash ~/.claude/install-resume-watchdog.sh
# to register the LaunchAgent (macOS) or systemd user-timer (Linux).
# /omc-config can do this for you.
# Env: OMC_RESUME_WATCHDOG.
#resume_watchdog=off

# Per-artifact cooldown (seconds) between watchdog launch attempts.
# Combined with the 3-attempt cap, this caps total retry effort at ~30
# minutes per artifact before the watchdog gives up. Default 600 = 10 min.
# Env: OMC_RESUME_WATCHDOG_COOLDOWN_SECS.
#resume_watchdog_cooldown_secs=600

# ---------------------------------------------------------------------------
# Time tracking — surface "where did this prompt's time go?" via
# per-tool / per-subagent capture, a Stop epilogue one-liner, and the
# `/ulw-time` skill (current session, last session, week / month / all
# cross-session rollups). The hook layer is append-only and lock-free
# on the hot path; opt out on shared machines or when residual disk
# noise (one JSONL per session under STATE_ROOT) is unwanted.
# ---------------------------------------------------------------------------

# Per-tool / per-subagent timing capture.
#   on  — capture; emit Stop epilogue; populate /ulw-time, /ulw-status,
#         /ulw-report. (Default.)
#   off — kill switch; PreToolUse / PostToolUse / Stop hooks fast-exit
#         in <1ms (no jq, no disk I/O); no rows captured.
# Env: OMC_TIME_TRACKING.
#time_tracking=on

# Cross-session timing rollup retention (days). Per-session timing.jsonl
# files are swept by state_ttl_days; the global aggregate at
# `~/.claude/quality-pack/timing.jsonl` has its own (tighter) horizon
# because workflow data is more privacy-sensitive than gate telemetry.
# Default 30 days — long enough for monthly reflection, short enough
# that workflow patterns do not accrue indefinitely on shared machines.
# Env: OMC_TIME_TRACKING_XS_RETAIN_DAYS.
#time_tracking_xs_retain_days=30

# Model-drift canary (v1.26.0 Wave 2). When `on`, the Stop hook runs a
# claims-vs-tool-calls audit: it parses the model's last response for
# assertive verification claims ("I read X", "I verified Y", "I checked
# Z", "the function in /path/to/file does ...") and compares the count
# against the actual Read/Bash/Grep tool calls that fired in the same
# turn. When the model claims verification work it did not do, an
# `unverified_claim` event lands in `<session>/canary.jsonl` and a
# cross-session aggregate at `~/.claude/quality-pack/canary.jsonl`.
# Surfaces in `/ulw-report` as a new "Canary signals" section. Soft
# in-session alert fires when the per-session count crosses threshold
# (one-shot per session). Lightweight: hook-based, no daemon, runs
# only at Stop. Default `on`. Opt out on shared machines / regulated
# codebases / very-high-volume workflows where the prose-parse cost is
# unwelcome.
#
# REQUIRES time_tracking=on. The audit reads <session>/timing.jsonl to
# count tool calls per prompt_seq; when time_tracking is off the canary
# short-circuits silently with no audit rows written. Minimal preset
# turns both off (consistent), maximum/balanced turn both on. If you
# want the canary on a custom config, ensure time_tracking is also on.
#
# Env: OMC_MODEL_DRIFT_CANARY.
#model_drift_canary=on

# ---------------------------------------------------------------------------
# Intent broadening — defend against the "language is a limitation" failure
# mode where a complex /ulw prompt names some surfaces but misses others.
# The blindspot inventory enumerates project surfaces (routes, env vars,
# tests, docs, config flags, UI files, error states, auth paths, release
# steps, scripts) so the model can reconcile its task scope against the
# project's real shape, not just the literal prompt text.
# ---------------------------------------------------------------------------

# Project surface inventory scanner. When `on` (default), the
# blindspot-inventory.sh scanner generates / refreshes
# ~/.claude/quality-pack/blindspots/<project_key>.json on demand, capped
# at 50 entries per surface so a typical scan finishes in under 2 seconds.
# The intent-broadening directive references the inventory; when this is
# off, the directive renders without the path reference (kill switch for
# shared machines / regulated codebases / very large monorepos where the
# scan is too expensive).
# Env: OMC_BLINDSPOT_INVENTORY.
#blindspot_inventory=on

# Inject a project-context reconciliation directive on complex execution
# / continuation prompts. Tells the model to enumerate the surfaces this
# work plausibly affects (release steps, env vars, tests, docs) and
# reconcile against the prompt — surfacing gaps in the opener under a
# "**Project surfaces touched:**" line rather than silently filling them.
# Default ON. Lighter than a hard gate: informational, expects the model
# to either ship the gap or defer with a one-line WHY. Independent of
# `blindspot_inventory` — a user may want the discipline without the
# scanner running, in which case the directive renders without an
# inventory reference.
# Env: OMC_INTENT_BROADENING.
#intent_broadening=on

# Cache TTL (seconds) for the blindspot inventory. Default 86400 = 24h —
# long enough for free reuse within a day, short enough that surfaces
# added today don't go missing for more than a day. Refresh on demand
# via `bash ~/.claude/skills/autowork/scripts/blindspot-inventory.sh
# scan --force`.
# Env: OMC_BLINDSPOT_TTL_SECONDS.
#blindspot_ttl_seconds=86400

# ---------------------------------------------------------------------------
# Cleanup.
# ---------------------------------------------------------------------------

# Days before stale per-session state directories are swept. Default 7.
# State carries the session's classifier telemetry, gate events, finding
# list, and resume artifacts — sweeping is what keeps `~/.claude/quality-
# pack/state/` from growing without bound on long-running setups.
# Env: OMC_STATE_TTL_DAYS.
#state_ttl_days=7

# ---------------------------------------------------------------------------
# Metadata (set by install.sh — do not edit by hand)
# ---------------------------------------------------------------------------
# repo_path=...           # absolute path to the source repo
# installed_version=...   # version captured by the last install
# installed_sha=...       # source-repo HEAD at last install (git only)
# omc_config_completed=...# ISO timestamp written by /omc-config at first run
