{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-claude.local/schemas/realwork-quality-probe.json",
  "title": "oh-my-claude blind pairwise quality probe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "domain",
    "risk",
    "fixture",
    "prompt",
    "candidate_artifacts",
    "hard_checks",
    "rubric",
    "campaign"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "domain": {
      "type": "string",
      "enum": ["coding", "design", "writing", "research", "quantitative", "operations", "mixed", "control"]
    },
    "risk": {"type": "string", "enum": ["low", "medium", "high"]},
    "fixture": {"type": "string", "minLength": 1},
    "prompt": {"type": "string", "minLength": 1},
    "candidate_artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {"type": "string", "enum": ["git_diff", "files", "rendered_images", "rendered_document"]},
          "globs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?!\\.pairwise(?:/|$))(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\u0000-\\u001f\\u007f]+$"
            }
          }
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "git_diff"}}, "required": ["kind"]},
            "then": {"not": {"required": ["globs"]}},
            "else": {"required": ["globs"]}
          }
        ]
      }
    },
    "hard_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "critical"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]+$"},
          "description": {"type": "string", "minLength": 1},
          "critical": {"type": "boolean"}
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "audience", "constraints", "non_goals", "task_specific_anchors", "dimensions"],
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "audience": {"type": "string", "minLength": 1},
        "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "non_goals": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "task_specific_anchors": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "dimensions": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "weight"],
            "properties": {
              "id": {
                "type": "string",
                "enum": ["deliberate", "distinctive", "coherent", "visionary", "complete"]
              },
              "weight": {"const": 1}
            }
          }
        }
      }
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runs_per_arm",
        "model_tiers",
        "max_candidate_cost_ratio",
        "max_candidate_wall_ratio",
        "candidate_summary_contract"
      ],
      "properties": {
        "runs_per_arm": {"type": "integer", "minimum": 1},
        "model_tiers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "enum": ["quality", "balanced", "economy"]}
        },
        "max_candidate_cost_ratio": {"type": "number", "minimum": 1},
        "max_candidate_wall_ratio": {"type": "number", "minimum": 1},
        "candidate_summary_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "required_top_level",
            "generation_authority",
            "required_token_economics"
          ],
          "properties": {
            "schema_version": {"const": 4},
            "required_top_level": {
              "const": ["schema_version", "probe_id", "generation_receipt", "generation_receipt_hash", "artifact_dir"]
            },
            "generation_authority": {"const": "evaluator-owned-cli-telemetry-v1"},
            "required_token_economics": {
              "const": ["input", "output", "cache_read", "cache_creation"]
            }
          }
        }
      }
    }
  }
}
