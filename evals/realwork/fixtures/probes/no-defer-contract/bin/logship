#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/lib/parse.sh"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/lib/render.sh"

usage() {
  cat <<'EOF'
logship — ship a log line in a chosen format

Usage: logship [--format plain|boxed] [--legacy-mode] <line>

  --format FORMAT   Output format: plain (default) or boxed.
  --legacy-mode     Deprecated since 0.9; will be removed in 1.0.
EOF
}

main() {
  [[ $# -gt 0 ]] || { usage >&2; exit 2; }
  parse_args "$@"
  render_line "${PARSED_FORMAT}" "${PARSED_INPUT}"
}

main "$@"
