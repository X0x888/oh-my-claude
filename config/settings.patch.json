{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "outputStyle": "oh-my-claude",
  "effortLevel": "high",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Inspecting",
      "Sketching",
      "Refining",
      "Verifying"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-resume-handoff.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-compact-handoff.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-resume-hint.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-drift-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-whats-new.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-welcome.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/prompt-intent-router.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/pretool-timing.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-pending-agent.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/pretool-intent-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/posttool-timing.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/mark-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-delivery-action.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__(browser_snapshot|browser_take_screenshot|browser_console_messages|browser_network_requests|browser_evaluate|browser_run_code)|mcp__computer-use__screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/reflect-after-agent.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-advisory-verification.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/pre-compact-snapshot.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/post-compact-summary.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/autowork/scripts/record-subagent-summary.sh"
          }
        ]
      },
      {
        "matcher": "quality-planner",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "prometheus",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "quality-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "editor-critic",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh prose"
          }
        ]
      },
      {
        "matcher": "superpowers:code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "feature-dev:code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "excellence-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh excellence"
          }
        ]
      },
      {
        "matcher": "release-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh release"
          }
        ]
      },
      {
        "matcher": "metis",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh stress_test"
          }
        ]
      },
      {
        "matcher": "briefing-analyst",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh traceability"
          }
        ]
      },
      {
        "matcher": "design-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh design_quality"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/stop-guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/stop-time-summary.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/canary-claim-audit.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/stop-failure-handler.sh"
          }
        ]
      }
    ]
  }
}
