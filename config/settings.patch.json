{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "outputStyle": "OpenCode Compact",
  "effortLevel": "high",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Inspecting",
      "Sketching",
      "Refining",
      "Verifying"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-resume-handoff.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-compact-handoff.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/prompt-intent-router.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/mark-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/reflect-after-agent.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-advisory-verification.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/pre-compact-snapshot.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/post-compact-summary.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/autowork/scripts/record-subagent-summary.sh"
          }
        ]
      },
      {
        "matcher": "quality-planner",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "prometheus",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "quality-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "editor-critic",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/stop-guard.sh"
          }
        ]
      }
    ]
  }
}
