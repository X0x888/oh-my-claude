{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "outputStyle": "oh-my-claude",
  "effortLevel": "high",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Inspecting",
      "Sketching",
      "Refining",
      "Verifying"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-resume-handoff.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-compact-handoff.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-resume-hint.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-watchdog-health.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-drift-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-whats-new.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-welcome.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-self-audit-nudge.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/session-start-auto-tune.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/first-prompt-session-init.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/prompt-intent-router.sh"
          }
        ]
      }
    ],
    "MessageDisplay": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/closeout-display.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/dispatch-recovery-guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/pretool-timing.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-tool-start-revision.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-pending-agent.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/quality-constitution-authority-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/pretool-intent-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/posttool-dispatch.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/mark-edit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/reflect-after-agent.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-advisory-verification.sh"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/closeout-preflight.sh --posttool-batch"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/pre-compact-snapshot.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/post-compact-summary.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/mark-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-verification.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-pending-agent.sh start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/autowork/scripts/record-subagent-summary.sh"
          }
        ]
      },
      {
        "matcher": "quality-planner",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "prometheus",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-plan.sh"
          }
        ]
      },
      {
        "matcher": "quality-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "editor-critic",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh prose"
          }
        ]
      },
      {
        "matcher": "superpowers:code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "feature-dev:code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh"
          }
        ]
      },
      {
        "matcher": "excellence-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh excellence"
          }
        ]
      },
      {
        "matcher": "release-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh release"
          }
        ]
      },
      {
        "matcher": "metis",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh stress_test"
          }
        ]
      },
      {
        "matcher": "briefing-analyst",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh traceability"
          }
        ]
      },
      {
        "matcher": "design-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/record-reviewer.sh design_quality"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/autowork/scripts/stop-dispatch.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/quality-pack/scripts/stop-failure-handler.sh"
          }
        ]
      }
    ]
  }
}
